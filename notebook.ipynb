   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# Assuming df['Long_Wait'] exists\n",
    "# Encode Day of Week as numbers (Monday=0 ... Sunday=6)\n",
    "day_mapping = {'Monday':0, 'Tuesday':1, 'Wednesday':2, 'Thursday':3,\n",
    "               'Friday':4, 'Saturday':5, 'Sunday':6}\n",
    "df['Day_Num'] = df['Day of Week'].map(day_mapping)\n",
    "\n",
    "# Encode Time of Day as numeric or categorical index\n",
    "# Let's just use an ordinal approach for simplicity\n",
    "time_mapping = {'Early Morning':0, 'Morning':1, 'Late Morning':2,\n",
    "                'Afternoon':3, 'Evening':4, 'Night':5}\n",
    "df['Time_Num'] = df['Time of Day'].map(time_mapping)\n",
    "df['Long_Wait'] = (df['Total Wait Time (min)'] > 120).astype(int)\n",
    "\n",
    "X = df[['Day_Num', 'Time_Num']].values\n",
    "y = df['Long_Wait'].values"
   ]
