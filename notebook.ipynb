   "source": [
    "fig = plt.figure(figsize=(10,7))\n",
    "ax = fig.add_subplot(111, projection='3d')\n",
    "\n",
    "# Surface plot for probability\n",
    "surf = ax.plot_surface(day_grid, time_grid, prob_grid, cmap='coolwarm', alpha=0.7)\n",
    "\n",
    "# Scatter actual points\n",
    "ax.scatter(df['Day_Num'], df['Time_Num'], df['Long_Wait'], c=df['Long_Wait'],\n",
    "           cmap='coolwarm', edgecolor='k', alpha=0.5)\n",
    "\n",
    "ax.set_xlabel('Day of Week')\n",
    "ax.set_ylabel('Time of Day')\n",
    "ax.set_zlabel('Probability of Long Wait / Actual')\n",
    "ax.set_title('3D Logistic Regression: Day & Time vs Long Wait')\n",
    "\n",
    "fig.colorbar(surf, shrink=0.5, aspect=5, label='Predicted Probability')\n",
    "plt.show()"
   ]
  },
