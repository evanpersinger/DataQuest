    "from mpl_toolkits.mplot3d import Axes3D\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Create mesh grid\n",
    "day_range = np.linspace(0, 6, 50)\n",
    "time_range = np.linspace(0, 5, 50)\n",
    "day_grid, time_grid = np.meshgrid(day_range, time_range)\n",
    "grid_points = np.c_[day_grid.ravel(), time_grid.ravel()]\n",
    "\n",
    "# Predict probabilities\n",
    "prob_grid = logreg.predict_proba(grid_points)[:,1].reshape(day_grid.shape)"
   ]
