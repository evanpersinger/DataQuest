    "import plotly.graph_objects as go\n",
    "from sklearn.linear_model import LogisticRegression\n",
    "import numpy as np\n",
    "\n",
    "# Prepare data (same as before)\n",
    "day_mapping = {'Monday':0, 'Tuesday':1, 'Wednesday':2, 'Thursday':3,\n",
    "               'Friday':4, 'Saturday':5, 'Sunday':6}\n",
    "time_mapping = {'Early Morning':0, 'Morning':1, 'Late Morning':2,\n",
    "                'Afternoon':3, 'Evening':4, 'Night':5}\n",
    "df['Day_Num'] = df['Day of Week'].map(day_mapping)\n",
    "df['Time_Num'] = df['Time of Day'].map(time_mapping)\n",
    "\n",
    "X = df[['Day_Num', 'Time_Num']].values\n",
    "y = df['Long_Wait'].values\n",
    "\n",
    "# Fit logistic regression\n",
    "logreg = LogisticRegression()\n",
    "logreg.fit(X, y)\n",
    "\n",
    "# Create a grid\n",
    "day_range = np.linspace(0, 6, 50)\n",
    "time_range = np.linspace(0, 5, 50)\n",
    "day_grid, time_grid = np.meshgrid(day_range, time_range)\n",
    "grid_points = np.c_[day_grid.ravel(), time_grid.ravel()]\n",
    "\n",
    "# Predict probabilities\n",
    "prob_grid = logreg.predict_proba(grid_points)[:,1].reshape(day_grid.shape)\n",
    "\n",
    "# Plotly surface\n",
    "fig = go.Figure()\n",
    "\n",
    "# Surface\n",
    "fig.add_trace(go.Surface(\n",
    "    x=day_grid, y=time_grid, z=prob_grid,\n",
    "    colorscale='RdBu', opacity=0.7, name='Predicted Probability'\n",
    "))\n",
    "\n",
    "# Scatter actual points\n",
    "fig.add_trace(go.Scatter3d(\n",
    "    x=df['Day_Num'],\n",
    "    y=df['Time_Num'],\n",
    "    z=df['Long_Wait'],\n",
    "    mode='markers',\n",
    "    marker=dict(color=df['Long_Wait'], size=5, colorscale='RdBu'),\n",
    "    name='Actual Outcomes'\n",
    "))\n",
    "\n",
    "fig.update_layout(\n",
    "    scene=dict(\n",
    "        xaxis_title='Day of Week',\n",
    "        yaxis_title='Time of Day',\n",
    "        zaxis_title='Probability / Actual'\n",
    "    ),\n",
    "    title='Interactive 3D Logistic Regression: Day & Time vs Long Wait'\n",
    ")\n",
    "\n",
    "fig.show()"
   ]
